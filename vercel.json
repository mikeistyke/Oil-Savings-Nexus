{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/live-metrics.ts": {
      "maxDuration": 60
    },
    "api/visitor-stats.ts": {
      "maxDuration": 10
    },
    "api/affiliate-clicks.ts": {
      "maxDuration": 10
    }
  },
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
